---
import BaseLayout from '../layouts/BaseLayout.astro';
import yaml from 'js-yaml';
import fs from 'fs';

const cv = yaml.load(fs.readFileSync('./src/data/cv.yaml', 'utf8'));
---

<BaseLayout title="Curriculum Vitae" description={`Professional resume of ${cv.fullName}`}>
	<article class="space-y-16">
		<header class="border-b border-sys-text/5 pb-12">
			<h1 class="font-serif italic text-4xl mb-4">{cv.fullName}</h1>
			<p class="text-sys-muted font-sans text-sm uppercase tracking-[0.2em] mb-8">{cv.title}</p>
			
			<div class="flex flex-wrap gap-x-8 gap-y-2 text-sm font-sans text-sys-muted">
				<span class="flex items-center gap-2">
					<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
					{cv.location}
				</span>
				<a href={`mailto:${cv.email}`} class="flex items-center gap-2 no-underline hover:text-sys-accent">
					<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
					{cv.email}
				</a>
				<a href={`https://github.com/${cv.github}`} target="_blank" class="flex items-center gap-2 no-underline hover:text-sys-accent">
					<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
					{cv.github}
				</a>
			</div>
		</header>

		<section>
			<h2 class="font-sans text-xs uppercase tracking-[0.3em] text-sys-muted mb-8">Summary</h2>
			<div class="prose prose-stone">
				<p>{cv.summary}</p>
			</div>
		</section>

		<section>
			<h2 class="font-sans text-xs uppercase tracking-[0.3em] text-sys-muted mb-8">Experience</h2>
			<div class="space-y-12">
				{cv.experience?.map((exp) => (
					<div class="group">
						<div class="flex justify-between items-baseline mb-2">
							<h3 class="font-serif italic text-xl">{exp.role}</h3>
							<span class="font-sans text-xs text-sys-muted">{exp.date}</span>
						</div>
						<div class="flex justify-between items-baseline mb-4">
							<span class="font-sans text-sm font-bold text-sys-accent uppercase tracking-wider">{exp.company}</span>
							<span class="font-sans text-xs text-sys-muted/60">{exp.location}</span>
						</div>
						<ul class="list-none p-0 space-y-2">
							{exp.details.map((detail) => (
								<li class="flex gap-3 text-sm text-sys-text/80 leading-relaxed">
									<span class="text-sys-accent/40">—</span>
									<span>{detail}</span>
								</li>
							))}
						</ul>
					</div>
				))}
			</div>
		</section>

		<section>
			<h2 class="font-sans text-xs uppercase tracking-[0.3em] text-sys-muted mb-8">Education</h2>
			<div class="space-y-8">
				{cv.education?.map((edu) => (
					<div>
						<div class="flex justify-between items-baseline mb-2">
							<h3 class="font-serif italic text-xl">{edu.school}</h3>
							<span class="font-sans text-xs text-sys-muted">{edu.date}</span>
						</div>
						<p class="font-sans text-sm text-sys-text mb-4">{edu.degree}</p>
						{edu.details && (
							<ul class="list-none p-0 space-y-1">
								{edu.details.map((detail) => (
									<li class="text-xs text-sys-muted italic flex gap-2">
										<span>•</span>
										<span>{detail}</span>
									</li>
								))}
							</ul>
						)}
					</div>
				))}
			</div>
		</section>

		<section>
			<h2 class="font-sans text-xs uppercase tracking-[0.3em] text-sys-muted mb-8">Technical Skills</h2>
			<div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
				{cv.skills?.map((skill) => (
					<div>
						<h3 class="font-sans text-xs font-bold uppercase tracking-widest text-sys-accent mb-3">{skill.category}</h3>
						<div class="flex flex-wrap gap-2">
							{skill.list?.map((item) => (
								<span class="px-3 py-1 bg-sys-accent/5 text-sys-accent rounded-full text-xs font-sans tracking-tight">
									{item}
								</span>
							))}
						</div>
					</div>
				))}
			</div>
		</section>

		{cv.publications && (
			<section>
				<h2 class="font-sans text-xs uppercase tracking-[0.3em] text-sys-muted mb-8">Publications</h2>
				<div class="space-y-8">
					{cv.publications.map((pub) => (
						<div>
							<div class="flex justify-between items-baseline mb-2">
								<h3 class="font-serif italic text-lg">{pub.title}</h3>
								<span class="font-sans text-xs text-sys-muted">{pub.date}</span>
							</div>
							<p class="font-sans text-xs text-sys-text mb-1">{pub.authors}</p>
							<p class="font-sans text-[10px] text-sys-accent uppercase tracking-wider">{pub.venue}</p>
						</div>
					))}
				</div>
			</section>
		)}

		<section>
			<h2 class="font-sans text-xs uppercase tracking-[0.3em] text-sys-muted mb-8">Honours</h2>
			<div class="space-y-4">
				{cv.honours?.map((honour) => (
					<div class="flex justify-between items-center py-3 border-b border-sys-text/5 last:border-0">
						<span class="text-sm font-serif italic">{honour.title}</span>
						<span class="text-xs font-sans text-sys-muted">{honour.date}</span>
					</div>
				))}
			</div>
		</section>

		<div class="pt-12 flex justify-center">
			<a href={`${import.meta.env.BASE_URL}/resume.pdf`} class="flex items-center gap-3 font-sans text-xs uppercase tracking-widest bg-sys-accent text-white px-8 py-4 rounded-full hover:bg-sys-accent/80 transition-all no-underline shadow-lg shadow-sys-accent/20">
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
				Download PDF Version
			</a>
		</div>
	</article>
</BaseLayout>
